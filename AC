#include <iostream>
using namespace std;

// Abstract class
class Shape {
public:
    virtual void draw() = 0;  // pure virtual function
};

// Derived class
class Circle : public Shape {
public:
    void draw() {
        cout << "Drawing Circle" << endl;
    }
};

int main() {
    // Shape s; ❌ Not allowed (abstract class)

    Circle c;
    c.draw();

    return 0;
}
