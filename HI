#include <iostream>
using namespace std;

// Base class
class A {
public:
    void showA() {
        cout << "Class A" << endl;
    }
};

// Derived from A
class B : public A {
public:
    void showB() {
        cout << "Class B" << endl;
    }
};

// Derived from A
class C : public A {
public:
    void showC() {
        cout << "Class C" << endl;
    }
};

// Derived from B and C (Hybrid)
class D : public B, public C {
public:
    void showD() {
        cout << "Class D" << endl;
    }
};

int main() {
    D d;

    d.showB();
    d.showC();
    d.showD();

    // d.showA(); ❌ Ambiguity (comes from both B and C)

    return 0;
}
