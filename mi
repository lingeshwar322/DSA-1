#include <iostream>
using namespace std;

// Base class 1
class Father {
public:
    void showFather() {
        cout << "This is Father class" << endl;
    }
};

// Base class 2
class Mother {
public:
    void showMother() {
        cout << "This is Mother class" << endl;
    }
};

// Derived class (inherits from both Father and Mother)
class Child : public Father, public Mother {
public:
    void showChild() {
        cout << "This is Child class" << endl;
    }
};

int main() {
    Child c;

    c.showFather(); // from Father
    c.showMother(); // from Mother
    c.showChild();  // own function

    return 0;
}
