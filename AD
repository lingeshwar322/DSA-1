#include <iostream>
using namespace std;

class Base {
public:
    virtual ~Base() {   // virtual destructor
        cout << "Base Destructor" << endl;
    }
};

class Derived : public Base {
public:
    ~Derived() {
        cout << "Derived Destructor" << endl;
    }
};

int main() {
    Base* b = new Derived();
    delete b;   // important

    return 0;
}
